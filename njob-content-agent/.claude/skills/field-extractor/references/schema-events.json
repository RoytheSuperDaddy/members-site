{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "events",
  "type": "object",
  "required": ["event_date", "title", "tag", "category"],
  "additionalProperties": false,
  "properties": {
    "event_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "일정 날짜 (YYYY-MM-DD)"
    },
    "title": {
      "type": "string",
      "maxLength": 200,
      "description": "업무명"
    },
    "description": {
      "type": ["string", "null"],
      "description": "상세 설명"
    },
    "tag": {
      "type": "string",
      "enum": ["t-imp", "t-reg", "t-ddl"],
      "description": "중요/정기/마감 태그"
    },
    "tag_text": {
      "type": "string",
      "enum": ["중요", "정기", "마감"],
      "description": "tag 자동 매핑 (tag에서 파생)"
    },
    "category": {
      "type": "string",
      "enum": ["exam", "report", "reward", "education", "meeting", "sign", "general"],
      "description": "일정 카테고리"
    },
    "actions": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "액션 항목 배열"
    }
  }
}
